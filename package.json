{
  "name": "milieu-cli",
  "version": "0.1.0",
  "description": "Measure how legible your product is to AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "milieu": "./dist/cli/index.js",
    "milieu-cli": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "author": "Arun",
  "keywords": [
    "ai",
    "ai-agents",
    "llm",
    "seo",
    "cli",
    "scanner",
    "robots-txt",
    "llms-txt",
    "openapi",
    "schema-org",
    "content-score",
    "web-standards"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/simplyarun/milieu-content-score-cli.git"
  },
  "homepage": "https://github.com/simplyarun/milieu-content-score-cli#readme",
  "bugs": {
    "url": "https://github.com/simplyarun/milieu-content-score-cli/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4",
    "typescript": "^5.9",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}
